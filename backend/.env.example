# iHeritage - FastAPI Backend & Indexer Environment Configuration
# Copy this file to '.env' in the same folder and fill in your variables.

# Environment Mode (development | production)
ENV_MODE=development

# API Server Configurations
HOST=127.0.0.1
PORT=8000

# SQLite / Database setup
# In development, a local sqlite db is used.
# In production, this can point to a production sqlite, Postgres, or mysql URL.
DATABASE_URL=sqlite:///./iheritage.db

# JWT secret key for signature verification and authentication
JWT_SECRET=super_secret_temporary_key_change_me_in_production

# Web3 Provider RPC URLs
# Public anchoring layer (Local Anvil Public Node: http://127.0.0.1:8547 vs Sepolia Testnet RPC)
RPC_PUBLIC=http://127.0.0.1:8547

# Private trading layer (Local Anvil Private Node: http://127.0.0.1:8546 vs Polygon Amoy RPC)
RPC_PRIVATE=http://127.0.0.1:8546

# Web3 Museum Account details
# Admin/Museum address and key utilized by the backend relayer to execute fractional mints.
# For local dev, these match Account #0 of Anvil. In production, secure this key.
MUSEUM_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
MUSEUM_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Contract deployment details paths (for dynamic address ingestion)
# Points to the foundry project output directories.
DEPLOYED_ADDRESSES_PATH=/home/qtnghiep/COMP3080/contracts/deployed_addresses.json
ABI_MASTER_PATH=/home/qtnghiep/COMP3080/contracts/out/MasterNFT.sol/MasterNFT.json
ABI_FRAGMENT_PATH=/home/qtnghiep/COMP3080/contracts/out/FragmentMarketplace.sol/FragmentMarketplace.json
