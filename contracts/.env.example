# iHeritage - Smart Contract Deployment Environment Configuration
# Copy this file to '.env' in the same folder and fill in your variables.

# Target Environment (local | testnet | mainnet)
ENVIRONMENT=local

# Deployer Private Key
# For Local Anvil, this is Account #0 (pre-funded: 10000 ETH)
# In production/testnet, use a secure, funded deployer address key
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- LOCAL RPC ENDPOINTS ---
# Local Anvil Port 8547: Public Layer (Anchoring)
RPC_URL_PUBLIC_LOCAL=http://127.0.0.1:8547
# Local Anvil Port 8546: Private Layer (Trading)
RPC_URL_PRIVATE_LOCAL=http://127.0.0.1:8546

# --- PRODUCTION/TESTNET RPC ENDPOINTS ---
# Public Chain (Polygon Amoy Testnet - Chain ID: 80002)
RPC_URL_PUBLIC_TESTNET=https://polygon-amoy.drpc.org
# Private Chain (Custom App-Chain / Private Node on Live Cloud Server)
RPC_URL_PRIVATE_TESTNET=https://polygon-amoy.g.alchemy.com/v2/your-alchemy-api-key

# --- CONTRACTS PARAMETERS ---
# Default Museum/Admin Address
# For Local Anvil, this matches Account #0
MUSEUM_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
